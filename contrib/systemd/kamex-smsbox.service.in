[Unit]
Description=Kamex SMSBox Service
After=kamex-bearerbox.service network.target
Requires=kamex-bearerbox.service
Documentation=https://kamex.dev

[Service]
Type=simple
StandardOutput=journal
StandardError=journal
ExecStart=@SBINDIR@/smsbox -v 1 /etc/kamex/kamex.conf
ExecReload=/bin/kill -HUP $MAINPID
Restart=always
RestartSec=5
TimeoutStartSec=30
TimeoutStopSec=30
User=kamex
Group=kamex

# Directory management (systemd creates these automatically)
RuntimeDirectory=kamex
RuntimeDirectoryMode=0755
StateDirectory=kamex
StateDirectoryMode=0755
LogsDirectory=kamex
LogsDirectoryMode=0755

# Security hardening (ProtectSystem=yes: /usr + /boot RO; strict mounts almost entire FS RO and can break startup)
NoNewPrivileges=true
ProtectSystem=yes
ProtectHome=true
ReadWritePaths=/var/log/kamex /var/spool/kamex /var/run/kamex

[Install]
WantedBy=multi-user.target
